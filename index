<!DOCTYPE html> 
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>El Sabor del Concepto — Comandá tu Creatividad</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700;800&family=Playfair+Display:wght@400;600;700&family=Caveat:wght@500;700&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">
<style>
  :root{
    --violeta: #7B62F2;
    --violeta-dark: #5C46D9;
    --lavanda: #B4ACFF;
    --menta: #6BFFA9;
    --crema: #FAF8FF;
    --tinta: #221A3D;
    --tinta-soft: #5C5478;
    --card-border: #E4DFFF;
    --radius: 22px;
  }

  *{box-sizing:border-box;}
  html{scroll-behavior:smooth;}

  body{
    margin:0;
    font-family:'Poppins', sans-serif;
    background:var(--crema);
    color:var(--tinta);
    min-height:100vh;
    position:relative;
    overflow-x:hidden;
  }

  .wrap{
    position:relative;
    z-index:1;
    max-width:880px;
    margin:0 auto;
    padding:64px 24px 100px;
  }

  header{
    text-align:center;
    margin-bottom:48px;
  }
  .eyebrow{
    display:inline-block;
    font-size:13px;
    font-weight:700;
    letter-spacing:0.12em;
    text-transform:uppercase;
    color:var(--violeta);
    background:#EFEBFF;
    padding:6px 16px;
    border-radius:999px;
    margin-bottom:18px;
  }
  h1{
    font-size:clamp(34px,6vw,52px);
    font-weight:800;
    line-height:1.05;
    margin:0 0 14px;
    letter-spacing:-0.02em;
  }
  h1 span{color:var(--violeta);}
  .intro{
    font-size:16px;
    color:var(--tinta-soft);
    line-height:1.6;
    max-width:560px;
    margin:0 auto;
  }

  /* Sección sabor */
  .flavor-zone{
    background:linear-gradient(135deg, #8C76F5 0%, var(--violeta) 55%, #6B52E0 100%);
    border-radius:40px;
    padding:48px 32px;
    text-align:center;
    color:white;
    margin-bottom:52px;
    position:relative;
    overflow:hidden;
    box-shadow:0 20px 50px -16px rgba(123,98,242,0.55);
  }
  .flavor-zone::before{
    content:"";
    position:absolute;
    width:280px;
    height:280px;
    top:-110px;
    right:-90px;
    background:radial-gradient(circle, rgba(255,255,255,0.22), transparent 70%);
    border-radius:50%;
    filter:blur(2px);
  }
  .flavor-zone::after{
    content:"";
    position:absolute;
    width:220px;
    height:220px;
    bottom:-120px;
    left:-70px;
    background:radial-gradient(circle, rgba(107,255,169,0.18), transparent 70%);
    border-radius:50%;
  }
  .flavor-label{
    font-size:13px;
    font-weight:600;
    letter-spacing:0.1em;
    text-transform:uppercase;
    opacity:0.85;
    margin-bottom:10px;
  }
  .flavor-display{
    font-size:clamp(38px,8vw,56px);
    font-weight:800;
    min-height:1.2em;
    letter-spacing:-0.01em;
    margin-bottom:24px;
    position:relative;
  }
  .flavor-display.rolling{
    animation:pulse 0.22s ease-in-out infinite alternate;
  }
  @keyframes pulse{from{opacity:1;transform:scale(1);}to{opacity:0.7;transform:scale(0.97);}}

  .roll-btn{
    background:var(--menta);
    color:var(--tinta);
    border:none;
    font-family:'Poppins',sans-serif;
    font-weight:700;
    font-size:16px;
    padding:16px 36px;
    border-radius:999px;
    cursor:pointer;
    transition:transform 0.25s cubic-bezier(.34,1.56,.64,1), box-shadow 0.25s ease, background 0.2s ease;
    box-shadow:0 10px 24px -8px rgba(0,0,0,0.28), 0 2px 4px rgba(0,0,0,0.08);
    position:relative;
  }
  .roll-btn:hover{transform:translateY(-3px) scale(1.02);box-shadow:0 16px 30px -10px rgba(0,0,0,0.3);background:#7DFFB5;}
  .roll-btn:active{transform:translateY(-1px) scale(0.98);box-shadow:0 6px 14px -6px rgba(0,0,0,0.25);}
  .roll-btn:disabled{opacity:0.6;cursor:not-allowed;transform:none;}

  /* Tablero */
  #board{
    transition:opacity 0.4s ease;
  }
  #board.locked{
    opacity:0.35;
    filter:grayscale(0.5);
    pointer-events:none;
  }

  .board-hint{
    text-align:center;
    font-size:14px;
    color:var(--tinta-soft);
    margin-bottom:28px;
  }
  .board-hint strong{color:var(--violeta);}

  .grid{
    display:grid;
    grid-template-columns:repeat(2,1fr);
    gap:18px;
  }
  @media (max-width:640px){.grid{grid-template-columns:1fr;}}

  .card{
    background:white;
    border:2px solid var(--card-border);
    border-radius:var(--radius);
    padding:22px;
    display:flex;
    flex-direction:column;
    gap:10px;
    opacity:0;
    transform:translateY(14px);
    animation:none;
  }
  #board.revealed .card{
    animation:rise 0.5s ease forwards;
  }
  @keyframes rise{to{opacity:1;transform:translateY(0);}}

  .card-icon{
    width:34px;height:34px;
    border-radius:10px;
    display:flex;align-items:center;justify-content:center;
    font-size:17px;
    background:var(--lavanda);
  }
  .card:nth-child(2n) .card-icon{background:var(--menta);}

  .card-label{
    font-weight:700;
    font-size:15px;
  }
  .card textarea{
    font-family:'Poppins',sans-serif;
    font-size:14px;
    border:1.5px solid var(--card-border);
    border-radius:12px;
    padding:10px 12px;
    resize:none;
    min-height:54px;
    background:#FCFBFF;
    color:var(--tinta);
    outline:none;
    transition:border-color 0.15s ease;
  }
  .card textarea:focus{border-color:var(--violeta);}

  /* Acciones finales */
  .actions{
    display:flex;
    gap:14px;
    justify-content:center;
    flex-wrap:wrap;
    margin-top:42px;
  }
  .btn-secondary, .btn-outline{
    font-family:'Poppins',sans-serif;
    font-weight:600;
    font-size:14px;
    padding:13px 26px;
    border-radius:999px;
    cursor:pointer;
    border:none;
  }
  .btn-secondary{
    background:var(--tinta);
    color:white;
  }
  .btn-secondary:hover{background:var(--violeta-dark);}
  .btn-outline{
    background:transparent;
    color:var(--tinta);
    border:1.5px solid var(--card-border);
  }
  .btn-outline:hover{border-color:var(--violeta);color:var(--violeta);}

  /* Tarjeta exportable */
  #export-card{
    position:fixed;
    left:-9999px;
    top:0;
    width:600px;
    background:var(--violeta);
    border-radius:28px;
    padding:36px;
    color:white;
    font-family:'Poppins',sans-serif;
  }
  #export-card .ex-eyebrow{font-size:12px;letter-spacing:0.1em;text-transform:uppercase;opacity:0.8;margin-bottom:6px;}
  #export-card h2{font-size:30px;margin:0 0 4px;font-weight:800;}
  #export-card .ex-flavor{font-size:15px;margin-bottom:22px;opacity:0.9;}
  #export-card .ex-grid{display:grid;grid-template-columns:1fr 1fr;gap:14px;}
  #export-card .ex-item{background:rgba(255,255,255,0.12);border-radius:14px;padding:14px;}
  #export-card .ex-item .ex-label{font-size:11px;text-transform:uppercase;letter-spacing:0.06em;opacity:0.75;margin-bottom:4px;}
  #export-card .ex-item .ex-value{font-size:14px;font-weight:600;word-wrap:break-word;}
  #export-card footer{margin-top:22px;font-size:12px;opacity:0.7;text-align:right;}

  footer.brand-band{
    margin-top:60px;
    text-align:center;
    font-size:12px;
    color:var(--tinta-soft);
    letter-spacing:0.04em;
  }
  footer.brand-band b{color:var(--violeta);}

  /* ===== Moodboard ===== */
  .mb-cta-wrap{
    text-align:center;
    margin-top:8px;
  }
  .btn-moodboard{
    font-family:'Poppins',sans-serif;
    font-weight:700;
    font-size:15px;
    padding:15px 30px;
    border-radius:999px;
    cursor:pointer;
    border:none;
    background:var(--violeta);
    color:white;
    box-shadow:0 10px 24px -8px rgba(123,98,242,0.5);
    transition:transform 0.2s cubic-bezier(.34,1.56,.64,1), box-shadow 0.2s ease, background 0.2s ease;
  }
  .btn-moodboard:hover{transform:translateY(-2px) scale(1.02);background:var(--violeta-dark);}
  .btn-moodboard:disabled{opacity:0.4;cursor:not-allowed;transform:none;box-shadow:none;}

  .moodboard-section{
    display:none;
    margin-top:64px;
    border-top:2px dashed var(--card-border);
    padding-top:48px;
  }
  .moodboard-section.visible{display:block;}

  .mb-header{
    text-align:center;
    margin-bottom:28px;
  }
  .mb-header .eyebrow{margin-bottom:14px;}
  .mb-header h2{
    font-size:clamp(26px,5vw,38px);
    font-weight:800;
    margin:0 0 10px;
    letter-spacing:-0.02em;
  }
  .mb-header h2 span{color:var(--violeta);}
  .mb-header p{
    font-size:14.5px;
    color:var(--tinta-soft);
    max-width:480px;
    margin:0 auto;
    line-height:1.6;
  }

  .mb-toolbar{
    display:flex;
    flex-wrap:wrap;
    gap:10px;
    justify-content:center;
    margin-bottom:24px;
  }
  .mb-btn{
    font-family:'Poppins',sans-serif;
    font-weight:600;
    font-size:13.5px;
    padding:11px 20px;
    border-radius:999px;
    cursor:pointer;
    border:1.5px solid var(--card-border);
    background:white;
    color:var(--tinta);
    transition:border-color 0.15s ease, color 0.15s ease, transform 0.15s ease;
    display:inline-flex;
    align-items:center;
    gap:6px;
  }
  .mb-btn:hover{border-color:var(--violeta);color:var(--violeta);transform:translateY(-1px);}
  .mb-btn.primary{background:var(--tinta);color:white;border-color:var(--tinta);}
  .mb-btn.primary:hover{background:var(--violeta-dark);border-color:var(--violeta-dark);color:white;}
  .mb-btn input[type=file]{display:none;}

  /* Popover de color de fondo */
  .mb-popover-wrap{position:relative;}
  .mb-popover{
    display:none;
    position:absolute;
    top:calc(100% + 10px);
    left:50%;
    transform:translateX(-50%);
    background:white;
    border:1.5px solid var(--card-border);
    border-radius:18px;
    padding:16px;
    box-shadow:0 16px 36px -14px rgba(34,26,61,0.3);
    z-index:30;
    width:220px;
  }
  .mb-popover.open{display:block;}
  .mb-popover-title{
    font-size:13px;
    font-weight:700;
    color:var(--tinta);
    margin-bottom:12px;
  }
  .mb-swatch-row{
    display:flex;
    flex-wrap:wrap;
    gap:10px;
  }
  .mb-swatch{
    width:30px;height:30px;
    border-radius:50%;
    border:1.5px solid var(--card-border);
    cursor:pointer;
    padding:0;
    transition:transform 0.15s ease;
  }
  .mb-swatch:hover{transform:scale(1.12);}
  .mb-swatch-add{
    background:conic-gradient(from 90deg, #7B62F2, #B4ACFF, #6BFFA9, #FFD66B, #FF6BC4, #7B62F2);
    color:white;
    font-weight:800;
    font-size:16px;
    display:flex;align-items:center;justify-content:center;
    border:none;
  }
  .mb-swatch-eyedrop{
    background:#F4F2FF;
    font-size:14px;
    display:flex;align-items:center;justify-content:center;
  }

  /* Barra de herramientas de texto */
  .mb-text-toolbar{
    display:none;
    flex-wrap:wrap;
    align-items:center;
    gap:10px;
    background:white;
    border:1.5px solid var(--card-border);
    border-radius:16px;
    padding:10px 14px;
    margin-bottom:16px;
    justify-content:center;
  }
  .mb-text-toolbar.open{display:flex;}
  .mb-text-toolbar select{
    font-family:'Poppins',sans-serif;
    font-size:13px;
    font-weight:600;
    border:1.5px solid var(--card-border);
    border-radius:10px;
    padding:8px 10px;
    color:var(--tinta);
    background:white;
    cursor:pointer;
  }
  .mb-size-stepper{
    display:flex;
    align-items:center;
    gap:8px;
    border:1.5px solid var(--card-border);
    border-radius:10px;
    padding:4px 10px;
  }
  .mb-size-stepper button{
    border:none;
    background:#F4F2FF;
    color:var(--violeta);
    width:22px;height:22px;
    border-radius:50%;
    font-size:15px;
    font-weight:700;
    cursor:pointer;
    line-height:1;
  }
  .mb-size-stepper span{font-size:13px;font-weight:600;min-width:24px;text-align:center;}
  .mb-text-style-btn{
    width:34px;height:34px;
    border-radius:10px;
    border:1.5px solid var(--card-border);
    background:white;
    cursor:pointer;
    font-size:14px;
    color:var(--tinta);
  }
  .mb-text-style-btn.active{background:var(--violeta);border-color:var(--violeta);color:white;}
  .mb-text-color-btn{
    width:34px;height:34px;
    border-radius:50%;
    border:1.5px solid var(--card-border);
    cursor:pointer;
    overflow:hidden;
    display:block;
    background:conic-gradient(from 90deg, #7B62F2, #B4ACFF, #6BFFA9, #FFD66B, #FF6BC4, #7B62F2);
  }
  .mb-text-color-btn input[type=color]{
    opacity:0;
    width:100%;height:100%;
    cursor:pointer;
  }

  .mb-canvas-wrap{
    position:relative;
    border-radius:28px;
    overflow:hidden;
    box-shadow:0 16px 40px -18px rgba(34,26,61,0.25);
  }
  #mbCanvas{
    position:relative;
    width:100%;
    height:560px;
    background:
      radial-gradient(circle, #E4DFFF 1.5px, transparent 1.5px) 0 0/22px 22px,
      var(--crema);
    border-radius:28px;
    overflow:hidden;
    touch-action:none;
  }
  #mbCanvas.exporting .mb-handle{display:none !important;}
  #mbCanvas.exporting .mb-item.text.active .mb-frame{box-shadow:none !important;}
  #mbCanvas.exporting{box-shadow:none;}

  .mb-item{
    position:absolute;
    top:0;
    left:0;
    cursor:grab;
    user-select:none;
    touch-action:none;
    will-change:transform;
  }
  .mb-item:active{cursor:grabbing;}

  .mb-item.image .mb-frame{
    width:100%;
    height:100%;
    border-radius:14px;
    overflow:hidden;
    box-shadow:0 10px 24px -8px rgba(34,26,61,0.35);
    box-sizing:border-box;
  }
  .mb-item.image img{
    width:100%;
    height:100%;
    object-fit:cover;
    display:block;
  }

  .mb-item.note .mb-frame{
    width:100%;
    height:auto;
    border-radius:14px;
    padding:10px 16px;
    box-sizing:border-box;
    box-shadow:0 10px 22px -10px rgba(34,26,61,0.3);
    display:flex;
    align-items:center;
    justify-content:center;
    overflow:hidden;
  }
  .mb-item.note .mb-note-text{
    font-size:14px;
    font-weight:700;
    line-height:1.3;
    text-align:center;
  }

  .mb-item.text .mb-frame{
    width:100%;
    height:100%;
    padding:8px 10px;
    box-sizing:border-box;
    outline:none;
    cursor:text;
    min-width:40px;
    min-height:1.2em;
    color:var(--tinta);
    font-family:'Poppins', sans-serif;
    font-size:28px;
    line-height:1.2;
    word-break:break-word;
  }
  .mb-item.text.active .mb-frame{
    box-shadow:0 0 0 2px var(--violeta);
    border-radius:8px;
  }

  #mbCanvas.dragover{outline:3px dashed var(--violeta);outline-offset:-3px;}

  .mb-pin{
    position:absolute;
    top:-7px;
    left:50%;
    transform:translateX(-50%);
    width:14px;height:14px;
    border-radius:50%;
    box-shadow:0 3px 6px rgba(0,0,0,0.25);
    z-index:4;
    pointer-events:none;
  }

  .mb-handle{
    position:absolute;
    display:flex;
    align-items:center;
    justify-content:center;
    background:var(--tinta);
    color:white;
    border-radius:50%;
    font-size:12px;
    cursor:pointer;
    opacity:0;
    transition:opacity 0.15s ease;
    z-index:5;
  }
  .mb-item:hover .mb-handle, .mb-item.active .mb-handle{opacity:1;}
  .mb-handle.delete{
    width:24px;height:24px;
    top:-10px;right:-10px;
    background:#FF5C5C;
    cursor:pointer;
  }
  .mb-handle.resize{
    width:22px;height:22px;
    bottom:-9px;right:-9px;
    cursor:nwse-resize;
    background:var(--violeta);
  }
  .mb-handle.rotate{
    width:22px;height:22px;
    top:-30px;left:50%;
    transform:translateX(-50%);
    cursor:grab;
    background:var(--menta);
    color:var(--tinta);
  }
  .mb-handle.move{
    width:22px;height:22px;
    top:-9px;left:-9px;
    cursor:grab;
    background:var(--lavanda);
    color:var(--tinta);
    font-size:11px;
  }

  @media (max-width:640px){
    #mbCanvas{height:460px;}
  }

  .toast{
    position:fixed;
    bottom:24px;
    left:50%;
    transform:translateX(-50%) translateY(20px);
    background:var(--tinta);
    color:white;
    padding:12px 22px;
    border-radius:999px;
    font-size:13px;
    font-weight:600;
    opacity:0;
    pointer-events:none;
    transition:all 0.3s ease;
  }
  .toast.show{opacity:1;transform:translateX(-50%) translateY(0);}
</style>
</head>
<body>

<div class="wrap">
  <header>
    <span class="eyebrow">Bloque 1 — El concepto</span>
    <h1>El Sabor <span>del Concepto</span></h1>
    <p class="intro">Te va a tocar un sabor al azar. A partir de él vas a construir tu concepto en 7 dimensiones distintas — así se entrena la cabeza para tomar decisiones coherentes, no sueltas.</p>
  </header>

  <section class="flavor-zone">
    <div class="flavor-label">Tu sabor es</div>
    <div class="flavor-display" id="flavorDisplay">?</div>
    <button class="roll-btn" id="rollBtn">Girá tu sabor</button>
  </section>

  <p class="board-hint" id="boardHint">Girá el sabor para desbloquear el tablero.</p>

  <div class="grid" id="board" class="locked">
    <!-- cards inserted by JS -->
  </div>

  <div class="actions">
    <button class="btn-secondary" id="exportBtn">Descargar mi tablero</button>
    <button class="btn-outline" id="resetBtn">Volver a girar</button>
  </div>

  <div class="mb-cta-wrap">
    <button class="btn-moodboard" id="goMoodboardBtn" disabled>Armar mi moodboard →</button>
  </div>

  <section class="moodboard-section" id="moodboardSection">
    <div class="mb-header">
      <span class="eyebrow">Paso 2</span>
      <h2>Armá tu <span>Moodboard</span></h2>
      <p>Subí imágenes que representen tu concepto y sumá tus propias respuestas. Movelas, rotalas y armalas como quieras hasta que el conjunto se sienta vos.</p>
    </div>

    <div class="mb-toolbar">
      <label class="mb-btn primary">
        📷 Subir imágenes
        <input type="file" id="mbFileInput" accept="image/*" multiple>
      </label>
      <label class="mb-btn" id="mbBgLabel">
        🖼️ <span id="mbBgBtnText">Sumar fondo</span>
        <input type="file" id="mbBgInput" accept="image/*" style="display:none;">
      </label>

      <div class="mb-popover-wrap">
        <button class="mb-btn" id="mbColorBtn" type="button">🎨 Color de fondo</button>
        <div class="mb-popover" id="mbColorPopover">
          <div class="mb-popover-title">Colores del fondo</div>
          <div class="mb-swatch-row">
            <button class="mb-swatch mb-swatch-add" id="mbCustomColorBtn" type="button" title="Color personalizado">+</button>
            <button class="mb-swatch mb-swatch-eyedrop" id="mbEyedropBtn" type="button" title="Gotero">🧪</button>
            <button class="mb-swatch" data-color="#FAF8FF" style="background:#FAF8FF" title="Crema"></button>
            <button class="mb-swatch" data-color="#FFFFFF" style="background:#FFFFFF" title="Blanco"></button>
            <button class="mb-swatch" data-color="#7B62F2" style="background:#7B62F2" title="Violeta"></button>
            <button class="mb-swatch" data-color="#B4ACFF" style="background:#B4ACFF" title="Lavanda"></button>
            <button class="mb-swatch" data-color="#6BFFA9" style="background:#6BFFA9" title="Menta"></button>
            <button class="mb-swatch" data-color="#221A3D" style="background:#221A3D" title="Tinta"></button>
          </div>
          <input type="color" id="mbCustomColorInput" style="display:none;">
        </div>
      </div>

      <button class="mb-btn" id="mbAddTextBtn" type="button">🔤 Agregar texto</button>
      <button class="mb-btn" id="mbDownloadBtn">⬇️ Descargar moodboard</button>
      <button class="mb-btn" id="mbClearBtn">🗑️ Vaciar tablero</button>
    </div>

    <div class="mb-text-toolbar" id="mbTextToolbar">
      <select id="mbFontSelect" title="Tipografía">
        <option value="'Poppins', sans-serif">Poppins</option>
        <option value="'Playfair Display', serif">Playfair Display</option>
        <option value="'Caveat', cursive">Caveat</option>
        <option value="'Space Mono', monospace">Space Mono</option>
      </select>
      <div class="mb-size-stepper">
        <button type="button" id="mbSizeMinus">−</button>
        <span id="mbSizeValue">28</span>
        <button type="button" id="mbSizePlus">+</button>
      </div>
      <button type="button" class="mb-text-style-btn" id="mbBoldBtn" title="Negrita"><b>B</b></button>
      <button type="button" class="mb-text-style-btn" id="mbItalicBtn" title="Cursiva"><i>I</i></button>
      <button type="button" class="mb-text-style-btn" id="mbUnderlineBtn" title="Subrayado"><u>U</u></button>
      <label class="mb-text-color-btn" id="mbTextColorLabel" title="Color de texto">
        <input type="color" id="mbTextColorInput" value="#221A3D">
      </label>
    </div>

    <div class="mb-canvas-wrap">
      <div id="mbCanvas"></div>
    </div>
  </section>

  <footer class="brand-band">Comandá tu Creatividad — <b>Estudio Clericó</b></footer>
</div>

<div id="export-card">
  <div class="ex-eyebrow">Comandá tu Creatividad — Bloque 1</div>
  <h2>El Sabor del Concepto</h2>
  <div class="ex-flavor">Sabor: <span id="exFlavor">—</span></div>
  <div class="ex-grid" id="exGrid"></div>
  <footer>Estudio Clericó</footer>
</div>

<div class="toast" id="toast">Imagen descargada</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"></script>
<script>
  const FLAVORS = ["Dulce","Salada","Ácida","Agria","Picante"];
  const CATEGORIES = [
    {key:"color", label:"Color", icon:"🎨"},
    {key:"cancion", label:"Canción", icon:"🎵"},
    {key:"pelicula", label:"Película", icon:"🎬"},
    {key:"palabra", label:"Palabra", icon:"🔤"},
    {key:"clima", label:"Clima", icon:"🌤️"},
    {key:"emocion", label:"Emoción", icon:"💫"},
    {key:"tipografia", label:"Tipografía", icon:"🅰️"},
    {key:"libro", label:"Libro", icon:"📖"},
  ];

  const flavorDisplay = document.getElementById('flavorDisplay');
  const rollBtn = document.getElementById('rollBtn');
  const board = document.getElementById('board');
  const boardHint = document.getElementById('boardHint');
  const exportBtn = document.getElementById('exportBtn');
  const resetBtn = document.getElementById('resetBtn');
  const toast = document.getElementById('toast');

  let currentFlavor = null;

  // Render cards (locked, empty) on load
  function renderCards(){
    board.innerHTML = "";
    CATEGORIES.forEach(cat=>{
      const card = document.createElement('div');
      card.className = 'card';
      card.innerHTML = `
        <div class="card-icon">${cat.icon}</div>
        <div class="card-label">${cat.label}</div>
        <textarea data-key="${cat.key}" placeholder="¿Qué ${cat.label.toLowerCase()} asociás con tu sabor?"></textarea>
      `;
      board.appendChild(card);
    });
  }
  renderCards();
  board.classList.add('locked');

  function rollFlavor(){
    rollBtn.disabled = true;
    flavorDisplay.classList.add('rolling');
    let tick = 0;
    const totalTicks = 14;

    function nextTick(){
      flavorDisplay.textContent = FLAVORS[Math.floor(Math.random()*FLAVORS.length)];
      tick++;
      if(tick < totalTicks){
        // easing: arranca rápido y va frenando suavemente, como una ruleta real
        const progress = tick / totalTicks;
        const delay = 55 + Math.pow(progress, 2.2) * 220;
        setTimeout(nextTick, delay);
      } else {
        currentFlavor = FLAVORS[Math.floor(Math.random()*FLAVORS.length)];
        flavorDisplay.textContent = currentFlavor;
        flavorDisplay.classList.remove('rolling');
        rollBtn.disabled = false;
        rollBtn.textContent = "Volver a girar";
        unlockBoard();
      }
    }
    nextTick();
  }

  function unlockBoard(){
    board.classList.remove('locked');
    board.classList.add('revealed');
    boardHint.innerHTML = `Te tocó <strong>${currentFlavor}</strong>. Completá las 7 dimensiones pensando en ese sabor.`;
    document.getElementById('goMoodboardBtn').disabled = false;
  }

  rollBtn.addEventListener('click', rollFlavor);

  resetBtn.addEventListener('click', ()=>{
    currentFlavor = null;
    flavorDisplay.textContent = "?";
    rollBtn.textContent = "Girá tu sabor";
    board.classList.add('locked');
    board.classList.remove('revealed');
    boardHint.textContent = "Girá el sabor para desbloquear el tablero.";
    document.querySelectorAll('#board textarea').forEach(t=>t.value="");
    document.getElementById('goMoodboardBtn').disabled = true;
  });

  function showToast(msg){
    toast.textContent = msg;
    toast.classList.add('show');
    setTimeout(()=>toast.classList.remove('show'), 2400);
  }

  exportBtn.addEventListener('click', async ()=>{
    if(!currentFlavor){
      showToast("Primero girá tu sabor");
      return;
    }
    const exFlavor = document.getElementById('exFlavor');
    const exGrid = document.getElementById('exGrid');
    exFlavor.textContent = currentFlavor;
    exGrid.innerHTML = "";
    CATEGORIES.forEach(cat=>{
      const val = document.querySelector(`textarea[data-key="${cat.key}"]`).value.trim() || "—";
      const item = document.createElement('div');
      item.className = 'ex-item';
      item.innerHTML = `<div class="ex-label">${cat.label}</div><div class="ex-value">${val}</div>`;
      exGrid.appendChild(item);
    });

    const exportCard = document.getElementById('export-card');
    exportCard.style.left = "0px";
    exportCard.style.top = "-9999px";
    await new Promise(r=>setTimeout(r,50));
    const canvas = await html2canvas(exportCard, {backgroundColor:null, scale:2});
    exportCard.style.left = "-9999px";
    exportCard.style.top = "0px";

    const link = document.createElement('a');
    link.download = `el-sabor-del-concepto-${currentFlavor.toLowerCase()}.png`;
    link.href = canvas.toDataURL('image/png');
    link.click();
    showToast("Imagen descargada");
  });

  /* ===================== MOODBOARD ===================== */
  const goMoodboardBtn = document.getElementById('goMoodboardBtn');
  const moodboardSection = document.getElementById('moodboardSection');
  const mbCanvas = document.getElementById('mbCanvas');
  const mbFileInput = document.getElementById('mbFileInput');
  mbAddAnswersBtn_removed = null; // eliminado
  const mbDownloadBtn = document.getElementById('mbDownloadBtn');
  const mbClearBtn = document.getElementById('mbClearBtn');

  const NOTE_COLORS = [
    {bg:'#B4ACFF', text:'#221A3D'},
    {bg:'#6BFFA9', text:'#221A3D'},
    {bg:'#7B62F2', text:'#FFFFFF'},
  ];

  let zCounter = 10;
  let cascadeCount = 0;

  // ------- Historial (undo / redo) -------
  let history = [];
  let historyIndex = -1;
  let isRestoring = false;

  function captureState(){
    const items = Array.from(mbCanvas.querySelectorAll('.mb-item')).map(item=>{
      const type = item.classList.contains('image') ? 'image' : item.classList.contains('text') ? 'text' : 'note';
      const data = {
        type,
        x: parseFloat(item.dataset.x) || 0,
        y: parseFloat(item.dataset.y) || 0,
        rot: parseFloat(item.dataset.rot) || 0,
        width: item.style.width,
        height: item.style.height || '',
      };
      const pin = item.querySelector('.mb-pin');
      if(pin) data.pinColor = pin.style.background;

      if(type === 'image'){
        data.src = item.querySelector('img').src;
        data.aspect = item.dataset.aspect;
      } else if(type === 'text'){
        const frame = item.querySelector('.mb-frame');
        data.text = frame.textContent;
        data.fontFamily = frame.style.fontFamily;
        data.fontSize = frame.style.fontSize;
        data.color = frame.style.color;
        data.fontWeight = frame.style.fontWeight;
        data.fontStyle = frame.style.fontStyle;
        data.textDecoration = frame.style.textDecoration;
      } else {
        const frame = item.querySelector('.mb-frame');
        data.text = item.querySelector('.mb-note-text').textContent;
        data.bg = frame.style.background;
        data.color = frame.style.color;
      }
      return data;
    });
    return {
      bgImage: mbCanvas.style.backgroundImage || '',
      bgColor: mbCanvas.style.backgroundColor || '',
      items
    };
  }

  function pushHistory(){
    if(isRestoring) return;
    const state = captureState();
    history = history.slice(0, historyIndex + 1);
    history.push(state);
    historyIndex = history.length - 1;
    if(history.length > 60){ history.shift(); historyIndex--; }
  }

  function rebuildItem(data){
    const w = parseFloat(data.width) || 150;
    const h = data.height ? parseFloat(data.height) : null;
    const {item, frame} = buildItemShell(data.type, w, h);
    item.dataset.x = data.x;
    item.dataset.y = data.y;
    item.dataset.rot = data.rot;
    const pin = item.querySelector('.mb-pin');
    if(pin && data.pinColor) pin.style.background = data.pinColor;

    if(data.type === 'image'){
      item.dataset.aspect = data.aspect;
      const img = document.createElement('img');
      img.src = data.src;
      frame.appendChild(img);
    } else if(data.type === 'text'){
      frame.textContent = data.text;
      frame.style.fontFamily = data.fontFamily;
      frame.style.fontSize = data.fontSize;
      frame.style.color = data.color;
      frame.style.fontWeight = data.fontWeight;
      frame.style.fontStyle = data.fontStyle;
      frame.style.textDecoration = data.textDecoration;
    } else {
      frame.style.background = data.bg;
      frame.style.color = data.color;
      frame.innerHTML = `<div class="mb-note-text">${data.text}</div>`;
    }
    setTransform(item);
    bringToFront(item);
    mbCanvas.appendChild(item);
  }

  function restoreState(state){
    isRestoring = true;
    mbCanvas.querySelectorAll('.mb-item').forEach(el => el.remove());
    mbCanvas.style.backgroundImage = state.bgImage || '';
    mbCanvas.style.backgroundColor = state.bgColor || '';
    if(state.bgImage){
      mbCanvas.style.backgroundSize = 'cover';
      mbCanvas.style.backgroundPosition = 'center';
      mbCanvas.style.backgroundRepeat = 'no-repeat';
      mbBgBtnText.textContent = 'Cambiar fondo';
    } else {
      mbBgBtnText.textContent = 'Sumar fondo';
    }
    state.items.forEach(rebuildItem);
    updateEmptyHint();
    hideTextToolbar();
    isRestoring = false;
  }

  function undo(){
    if(historyIndex > 0){
      historyIndex--;
      restoreState(history[historyIndex]);
      showToast('Cambio deshecho');
    }
  }

  function redo(){
    if(historyIndex < history.length - 1){
      historyIndex++;
      restoreState(history[historyIndex]);
      showToast('Cambio rehecho');
    }
  }

  document.addEventListener('keydown', (e)=>{
    const key = e.key.toLowerCase();
    if(!(key === 'z' || key === 'y')) return;
    if(!(e.ctrlKey || e.metaKey)) return;

    const tag = document.activeElement ? document.activeElement.tagName : '';
    const isEditable = tag === 'TEXTAREA' || tag === 'INPUT' || (document.activeElement && document.activeElement.isContentEditable);
    if(isEditable) return; // dejamos el undo nativo del navegador en campos de texto

    if(!moodboardSection.classList.contains('visible')) return; // solo afecta al moodboard

    e.preventDefault();
    if(key === 'y' || (key === 'z' && e.shiftKey)) redo(); else undo();
  });

  goMoodboardBtn.addEventListener('click', ()=>{
    moodboardSection.classList.add('visible');
    moodboardSection.scrollIntoView({behavior:'smooth', block:'start'});
  });

  function updateEmptyHint(){
    // El hint de texto vacío ya no vive dentro del canvas (se sacó del moodboard).
  }

  function nextCascadePos(){
    cascadeCount++;
    const cw = mbCanvas.clientWidth || 600;
    const baseX = 40 + ((cascadeCount * 37) % Math.max(cw - 220, 120));
    const baseY = 30 + ((cascadeCount * 53) % 280);
    return {x: baseX, y: baseY};
  }

  function setTransform(item){
    const x = parseFloat(item.dataset.x) || 0;
    const y = parseFloat(item.dataset.y) || 0;
    const rot = parseFloat(item.dataset.rot) || 0;
    item.style.transform = `translate(${x}px, ${y}px) rotate(${rot}deg)`;
  }

  function bringToFront(item){
    zCounter++;
    item.style.zIndex = zCounter;
  }

  function deactivateAll(except){
    mbCanvas.querySelectorAll('.mb-item.active').forEach(el=>{
      if(el !== except) el.classList.remove('active');
    });
  }

  function buildItemShell(type, width, height){
    const item = document.createElement('div');
    item.className = `mb-item ${type}`;
    item.style.width = width + 'px';
    if(height){ item.style.height = height + 'px'; }
    item.dataset.x = 0; item.dataset.y = 0; item.dataset.rot = 0;

    if(type !== 'text'){
      const pin = document.createElement('div');
      pin.className = 'mb-pin';
      pin.style.background = ['#7B62F2','#B4ACFF','#6BFFA9'][Math.floor(Math.random()*3)];
      item.appendChild(pin);
    }

    const frame = document.createElement('div');
    frame.className = 'mb-frame';
    item.appendChild(frame);

    let moveBtn = null;
    if(type === 'text'){
      frame.contentEditable = 'true';
      frame.spellcheck = false;
      moveBtn = document.createElement('div');
      moveBtn.className = 'mb-handle move';
      moveBtn.textContent = '✥';
      item.appendChild(moveBtn);
    }

    const delBtn = document.createElement('div');
    delBtn.className = 'mb-handle delete';
    delBtn.textContent = '×';
    item.appendChild(delBtn);

    const resizeBtn = document.createElement('div');
    resizeBtn.className = 'mb-handle resize';
    resizeBtn.textContent = '⤡';
    item.appendChild(resizeBtn);

    const rotateBtn = document.createElement('div');
    rotateBtn.className = 'mb-handle rotate';
    rotateBtn.textContent = '↻';
    item.appendChild(rotateBtn);

    wireItemEvents(item, frame, delBtn, resizeBtn, rotateBtn, moveBtn);
    return {item, frame};
  }

  function wireItemEvents(item, frame, delBtn, resizeBtn, rotateBtn, moveBtn){
    const dragHandle = moveBtn || frame;
    // Arrastrar
    dragHandle.addEventListener('pointerdown', (e)=>{
      e.preventDefault();
      dragHandle.setPointerCapture(e.pointerId);
      bringToFront(item);
      deactivateAll(item);
      item.classList.add('active');
      if(item.classList.contains('text')) showTextToolbar(item); else hideTextToolbar();
      const startX = e.clientX, startY = e.clientY;
      const startTx = parseFloat(item.dataset.x), startTy = parseFloat(item.dataset.y);
      function onMove(ev){
        item.dataset.x = startTx + (ev.clientX - startX);
        item.dataset.y = startTy + (ev.clientY - startY);
        setTransform(item);
      }
      function onUp(ev){
        dragHandle.removeEventListener('pointermove', onMove);
        dragHandle.removeEventListener('pointerup', onUp);
        pushHistory();
      }
      dragHandle.addEventListener('pointermove', onMove);
      dragHandle.addEventListener('pointerup', onUp);
    });

    // Texto: click adentro para escribir, sin disparar arrastre
    if(item.classList.contains('text')){
      frame.addEventListener('pointerdown', (e)=> e.stopPropagation());
      frame.addEventListener('focus', ()=>{
        bringToFront(item);
        deactivateAll(item);
        item.classList.add('active');
        showTextToolbar(item);
      });
      frame.addEventListener('blur', ()=> pushHistory());
    }

    // Eliminar
    delBtn.addEventListener('pointerdown', (e)=>{
      e.stopPropagation();
      e.preventDefault();
      if(item === activeTextItem) hideTextToolbar();
      item.remove();
      updateEmptyHint();
      pushHistory();
    });

    // Redimensionar
    resizeBtn.addEventListener('pointerdown', (e)=>{
      e.stopPropagation();
      e.preventDefault();
      resizeBtn.setPointerCapture(e.pointerId);
      bringToFront(item);
      const startX = e.clientX, startY = e.clientY;
      const startW = item.offsetWidth, startH = item.offsetHeight;
      const aspect = item.dataset.aspect ? parseFloat(item.dataset.aspect) : null;
      function onMove(ev){
        const dx = ev.clientX - startX;
        let newW = Math.max(70, startW + dx);
        let newH;
        if(aspect){
          newH = newW / aspect;
        } else {
          const dy = ev.clientY - startY;
          newH = Math.max(50, startH + dy);
        }
        item.style.width = newW + 'px';
        item.style.height = newH + 'px';
      }
      function onUp(){
        resizeBtn.removeEventListener('pointermove', onMove);
        resizeBtn.removeEventListener('pointerup', onUp);
        pushHistory();
      }
      resizeBtn.addEventListener('pointermove', onMove);
      resizeBtn.addEventListener('pointerup', onUp);
    });

    // Rotar
    rotateBtn.addEventListener('pointerdown', (e)=>{
      e.stopPropagation();
      e.preventDefault();
      rotateBtn.setPointerCapture(e.pointerId);
      bringToFront(item);
      const rect = item.getBoundingClientRect();
      const cx = rect.left + rect.width/2;
      const cy = rect.top + rect.height/2;
      const startRot = parseFloat(item.dataset.rot) || 0;
      const startAngle = Math.atan2(e.clientY - cy, e.clientX - cx) * 180/Math.PI;
      function onMove(ev){
        const angle = Math.atan2(ev.clientY - cy, ev.clientX - cx) * 180/Math.PI;
        item.dataset.rot = startRot + (angle - startAngle);
        setTransform(item);
      }
      function onUp(){
        rotateBtn.removeEventListener('pointermove', onMove);
        rotateBtn.removeEventListener('pointerup', onUp);
        pushHistory();
      }
      rotateBtn.addEventListener('pointermove', onMove);
      rotateBtn.addEventListener('pointerup', onUp);
    });
  }

  function addImageItem(dataUrl, dropX, dropY){
    const img = new Image();
    img.onload = ()=>{
      const aspect = img.naturalWidth / img.naturalHeight;
      const width = 190;
      const height = width / aspect;
      const {item, frame} = buildItemShell('image', width, height);
      item.dataset.aspect = aspect;

      const imgEl = document.createElement('img');
      imgEl.src = dataUrl;
      frame.appendChild(imgEl);

      let pos;
      if(dropX !== undefined){
        pos = {x: dropX - width/2, y: dropY - height/2};
      } else {
        pos = nextCascadePos();
      }
      item.dataset.x = pos.x;
      item.dataset.y = pos.y;
      item.dataset.rot = Math.round(Math.random()*16 - 8);
      setTransform(item);
      bringToFront(item);

      mbCanvas.appendChild(item);
      updateEmptyHint();
      pushHistory();
    };
    img.src = dataUrl;
  }

  function addNoteItem(text){
    const width = Math.min(220, Math.max(90, text.length * 6.5 + 50));
    const {item, frame} = buildItemShell('note', width, null);
    const color = NOTE_COLORS[Math.floor(Math.random()*NOTE_COLORS.length)];
    frame.style.background = color.bg;
    frame.style.color = color.text;
    frame.innerHTML = `<div class="mb-note-text">${text}</div>`;

    const pos = nextCascadePos();
    item.dataset.x = pos.x;
    item.dataset.y = pos.y;
    item.dataset.rot = Math.round(Math.random()*14 - 7);
    setTransform(item);
    bringToFront(item);

    mbCanvas.appendChild(item);
    updateEmptyHint();
    pushHistory();
  }

  function addTextItem(){
    const {item, frame} = buildItemShell('text', 220, null);
    frame.textContent = 'Escribí algo';
    frame.style.fontFamily = "'Poppins', sans-serif";
    frame.style.fontSize = '28px';
    frame.style.color = '#221A3D';
    frame.style.fontWeight = '400';
    frame.style.fontStyle = 'normal';
    frame.style.textDecoration = 'none';

    const pos = nextCascadePos();
    item.dataset.x = pos.x;
    item.dataset.y = pos.y;
    item.dataset.rot = 0;
    setTransform(item);
    bringToFront(item);

    mbCanvas.appendChild(item);
    pushHistory();

    deactivateAll(item);
    item.classList.add('active');
    showTextToolbar(item);
    frame.focus();
    // Seleccionar el texto placeholder para que escriban directo encima
    const range = document.createRange();
    range.selectNodeContents(frame);
    const sel = window.getSelection();
    sel.removeAllRanges();
    sel.addRange(range);
  }

  // ------- Barra de herramientas de texto -------
  let activeTextItem = null;
  const mbTextToolbar = document.getElementById('mbTextToolbar');
  const mbFontSelect = document.getElementById('mbFontSelect');
  const mbSizeMinus = document.getElementById('mbSizeMinus');
  const mbSizePlus = document.getElementById('mbSizePlus');
  const mbSizeValue = document.getElementById('mbSizeValue');
  const mbBoldBtn = document.getElementById('mbBoldBtn');
  const mbItalicBtn = document.getElementById('mbItalicBtn');
  const mbUnderlineBtn = document.getElementById('mbUnderlineBtn');
  const mbTextColorInput = document.getElementById('mbTextColorInput');

  function showTextToolbar(item){
    activeTextItem = item;
    const frame = item.querySelector('.mb-frame');
    const cs = frame.style;
    mbFontSelect.value = cs.fontFamily || "'Poppins', sans-serif";
    mbSizeValue.textContent = parseInt(cs.fontSize, 10) || 28;
    mbBoldBtn.classList.toggle('active', cs.fontWeight === '700');
    mbItalicBtn.classList.toggle('active', cs.fontStyle === 'italic');
    mbUnderlineBtn.classList.toggle('active', cs.textDecoration === 'underline');
    mbTextColorInput.value = rgbToHex(cs.color) || '#221A3D';
    mbTextToolbar.classList.add('open');
  }

  function hideTextToolbar(){
    activeTextItem = null;
    mbTextToolbar.classList.remove('open');
  }

  function rgbToHex(rgb){
    if(!rgb) return '#221A3D';
    if(rgb.startsWith('#')) return rgb;
    const m = rgb.match(/\d+/g);
    if(!m) return '#221A3D';
    return '#' + m.slice(0,3).map(n=>parseInt(n,10).toString(16).padStart(2,'0')).join('');
  }

  mbFontSelect.addEventListener('change', ()=>{
    if(!activeTextItem) return;
    activeTextItem.querySelector('.mb-frame').style.fontFamily = mbFontSelect.value;
    pushHistory();
  });

  mbSizeMinus.addEventListener('click', ()=>{
    if(!activeTextItem) return;
    const frame = activeTextItem.querySelector('.mb-frame');
    const newSize = Math.max(10, (parseInt(frame.style.fontSize,10)||28) - 2);
    frame.style.fontSize = newSize + 'px';
    mbSizeValue.textContent = newSize;
    pushHistory();
  });
  mbSizePlus.addEventListener('click', ()=>{
    if(!activeTextItem) return;
    const frame = activeTextItem.querySelector('.mb-frame');
    const newSize = Math.min(160, (parseInt(frame.style.fontSize,10)||28) + 2);
    frame.style.fontSize = newSize + 'px';
    mbSizeValue.textContent = newSize;
    pushHistory();
  });

  mbBoldBtn.addEventListener('click', ()=>{
    if(!activeTextItem) return;
    const frame = activeTextItem.querySelector('.mb-frame');
    const isBold = frame.style.fontWeight === '700';
    frame.style.fontWeight = isBold ? '400' : '700';
    mbBoldBtn.classList.toggle('active', !isBold);
    pushHistory();
  });
  mbItalicBtn.addEventListener('click', ()=>{
    if(!activeTextItem) return;
    const frame = activeTextItem.querySelector('.mb-frame');
    const isItalic = frame.style.fontStyle === 'italic';
    frame.style.fontStyle = isItalic ? 'normal' : 'italic';
    mbItalicBtn.classList.toggle('active', !isItalic);
    pushHistory();
  });
  mbUnderlineBtn.addEventListener('click', ()=>{
    if(!activeTextItem) return;
    const frame = activeTextItem.querySelector('.mb-frame');
    const isUnderline = frame.style.textDecoration === 'underline';
    frame.style.textDecoration = isUnderline ? 'none' : 'underline';
    mbUnderlineBtn.classList.toggle('active', !isUnderline);
    pushHistory();
  });
  mbTextColorInput.addEventListener('input', ()=>{
    if(!activeTextItem) return;
    activeTextItem.querySelector('.mb-frame').style.color = mbTextColorInput.value;
  });
  mbTextColorInput.addEventListener('change', ()=> pushHistory());

  document.getElementById('mbAddTextBtn').addEventListener('click', addTextItem);

  function filesToImages(fileList){
    Array.from(fileList).forEach(file=>{
      if(!file.type.startsWith('image/')) return;
      const reader = new FileReader();
      reader.onload = (e)=> addImageItem(e.target.result);
      reader.readAsDataURL(file);
    });
  }

  mbFileInput.addEventListener('change', (e)=>{
    filesToImages(e.target.files);
    mbFileInput.value = '';
  });

  mbCanvas.addEventListener('dragover', (e)=>{
    e.preventDefault();
    mbCanvas.classList.add('dragover');
  });
  mbCanvas.addEventListener('dragleave', ()=> mbCanvas.classList.remove('dragover'));
  mbCanvas.addEventListener('drop', (e)=>{
    e.preventDefault();
    mbCanvas.classList.remove('dragover');
    const rect = mbCanvas.getBoundingClientRect();
    const dropX = e.clientX - rect.left;
    const dropY = e.clientY - rect.top;
    Array.from(e.dataTransfer.files).forEach(file=>{
      if(!file.type.startsWith('image/')) return;
      const reader = new FileReader();
      reader.onload = (ev)=> addImageItem(ev.target.result, dropX, dropY);
      reader.readAsDataURL(file);
    });
  });

  document.addEventListener('paste', (e)=>{
    if(!moodboardSection.classList.contains('visible')) return;
    const items = e.clipboardData ? e.clipboardData.items : [];
    Array.from(items).forEach(it=>{
      if(it.type.startsWith('image/')){
        const file = it.getAsFile();
        const reader = new FileReader();
        reader.onload = (ev)=> addImageItem(ev.target.result);
        reader.readAsDataURL(file);
      }
    });
  });

  mbCanvas.addEventListener('pointerdown', (e)=>{
    if(e.target === mbCanvas){
      deactivateAll();
      hideTextToolbar();
    }
  });

  // (mbAddAnswersBtn eliminado)

  const mbBgInput = document.getElementById('mbBgInput');
  const mbBgBtnText = document.getElementById('mbBgBtnText');

  mbBgInput.addEventListener('change', (e)=>{
    const file = e.target.files[0];
    if(!file || !file.type.startsWith('image/')) return;
    const reader = new FileReader();
    reader.onload = (ev)=>{
      mbCanvas.style.backgroundImage = `url(${ev.target.result})`;
      mbCanvas.style.backgroundSize = 'cover';
      mbCanvas.style.backgroundPosition = 'center';
      mbCanvas.style.backgroundRepeat = 'no-repeat';
      mbBgBtnText.textContent = 'Cambiar fondo';
      pushHistory();
    };
    reader.readAsDataURL(file);
    mbBgInput.value = '';
  });

  mbClearBtn.addEventListener('click', ()=>{
    mbCanvas.querySelectorAll('.mb-item').forEach(el=>el.remove());
    mbCanvas.style.backgroundImage = '';
    mbCanvas.style.backgroundColor = '';
    mbBgBtnText.textContent = 'Sumar fondo';
    updateEmptyHint();
    pushHistory();
  });

  // ------- Color de fondo (paleta tipo bote de pintura) -------
  const mbColorBtn = document.getElementById('mbColorBtn');
  const mbColorPopover = document.getElementById('mbColorPopover');
  const mbCustomColorBtn = document.getElementById('mbCustomColorBtn');
  const mbCustomColorInput = document.getElementById('mbCustomColorInput');
  const mbEyedropBtn = document.getElementById('mbEyedropBtn');

  function applyBgColor(color){
    mbCanvas.style.backgroundImage = '';
    mbCanvas.style.backgroundColor = color;
    mbBgBtnText.textContent = 'Sumar fondo';
    pushHistory();
  }

  mbColorBtn.addEventListener('click', (e)=>{
    e.stopPropagation();
    mbColorPopover.classList.toggle('open');
  });

  document.addEventListener('click', (e)=>{
    if(!mbColorPopover.contains(e.target) && e.target !== mbColorBtn){
      mbColorPopover.classList.remove('open');
    }
  });

  mbColorPopover.querySelectorAll('.mb-swatch[data-color]').forEach(sw=>{
    sw.addEventListener('click', ()=>{
      applyBgColor(sw.dataset.color);
      mbColorPopover.classList.remove('open');
    });
  });

  mbCustomColorBtn.addEventListener('click', ()=> mbCustomColorInput.click());
  mbCustomColorInput.addEventListener('input', ()=>{
    mbCanvas.style.backgroundImage = '';
    mbCanvas.style.backgroundColor = mbCustomColorInput.value;
  });
  mbCustomColorInput.addEventListener('change', ()=>{
    mbBgBtnText.textContent = 'Sumar fondo';
    pushHistory();
    mbColorPopover.classList.remove('open');
  });

  mbEyedropBtn.addEventListener('click', async ()=>{
    if(!window.EyeDropper){
      showToast('Tu navegador no soporta el gotero');
      return;
    }
    try{
      const eyeDropper = new EyeDropper();
      const result = await eyeDropper.open();
      applyBgColor(result.sRGBHex);
      mbColorPopover.classList.remove('open');
    }catch(err){
      // cancelado por el usuario, no hacemos nada
    }
  });

  mbDownloadBtn.addEventListener('click', async ()=>{
    if(mbCanvas.querySelectorAll('.mb-item').length === 0){
      showToast("Tu moodboard está vacío");
      return;
    }
    mbCanvas.classList.add('exporting');
    deactivateAll();
    hideTextToolbar();
    const bgColor = mbCanvas.style.backgroundColor || '#FAF8FF';
    const canvas = await html2canvas(mbCanvas, {backgroundColor: bgColor, scale:2});
    mbCanvas.classList.remove('exporting');
    const link = document.createElement('a');
    link.download = 'mi-moodboard-comanda-tu-creatividad.png';
    link.href = canvas.toDataURL('image/png');
    link.click();
    showToast("Moodboard descargado");
  });

  pushHistory(); // estado base, vacío

</script>
</body>
</html>
